DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
DATABASE_URL=postgresql://user:password@host:5432/database

# A long random secret — ASOP_Terminal sends this as: Authorization: Bearer <key>
ROLECALL_API_KEY=generate_a_long_random_secret_here

# Lock CORS to the ASOP_Terminal web app origin (e.g. https://asop.f919.org)
# Leave unset during local development to allow all origins
CORS_ORIGIN=
